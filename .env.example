# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=2048

# Airlabs Flight API Configuration
AIRLABS_API_KEY=your_airlabs_api_key_here
AIRLABS_BASE_URL=https://airlabs.co/api/v9

# Airtable Configuration
AIRTABLE_TOKEN=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_CUSTOMERS_TABLE=Customers
AIRTABLE_BOOKINGS_TABLE=Bookings
AIRTABLE_FLIGHTS_TABLE=Flights
AIRTABLE_PAYMENTS_TABLE=Payments

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
FROM_EMAIL=noreply@flightbooking.com
SUPPORT_EMAIL=support@flightbooking.com

# Speech Recognition Configuration
STT_ENGINE=google
STT_LANGUAGE=en-US
STT_MICROPHONE_INDEX=0

# Text-to-Speech Configuration
TTS_ENGINE=google
TTS_LANGUAGE=en-US
TTS_RATE=150
TTS_VOLUME=0.9

# Payment Processing
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Application Configuration
APP_NAME=AI Flight Booking System
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database Configuration (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/flight_booking

# Security
SECRET_KEY=your_secret_key_for_jwt
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Feature Flags
ENABLE_AUTO_PAYMENT=true
ENABLE_EMAIL_CONFIRMATION=true
ENABLE_PAYMENT_LINK=true
ENABLE_BOOKING_HISTORY=true

# Rate Limiting
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=3600

# Timeouts (in seconds)
API_TIMEOUT=30
STT_TIMEOUT=60
LLM_TIMEOUT=30

# Environment
ENVIRONMENT=development
